#!/usr/bin/env bash
# Tier-2 #9-C 本地 pre-commit hook
# 對要 commit 的 JS 檔做 node --check 語法檢查。
# 安裝：bash scripts/install-git-hooks.sh
set -euo pipefail

# 只檢查已 staged 的 .js 檔（不掃整個 repo）
CHANGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.js$' || true)

if [[ -z "$CHANGED" ]]; then
  exit 0
fi

echo "🔎 pre-commit: 檢查 $(echo "$CHANGED" | wc -l | tr -d ' ') 個 JS 檔..."

BAD=0
while IFS= read -r f; do
  [[ -z "$f" ]] && continue
  if [[ ! -f "$f" ]]; then continue; fi
  if ! node --check "$f" 2>/tmp/pre_commit_err; then
    echo "  ❌ $f"
    sed 's/^/     /' /tmp/pre_commit_err
    BAD=$((BAD+1))
  fi
done <<< "$CHANGED"

if [[ $BAD -gt 0 ]]; then
  echo
  echo "❌ 有 $BAD 個 JS 檔有語法錯誤，commit 中止。"
  echo "   （要繞過：git commit --no-verify）"
  exit 1
fi

echo "✅ 語法檢查通過"
